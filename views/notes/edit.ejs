<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <title>Редагувати нотатку</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <div class="card">
        <h2>Редагувати нотатку</h2>
        
        <form action="/notes/<%= note.id %>" method="POST">
            <input type="text" name="title" value="<%= note.title %>" required>
            
            <textarea name="content" rows="5" required
                style="width: 100%; background: #2d2d2d; color: white; border: 1px solid #3d3d3d; border-radius: 8px; padding: 12px; margin-bottom: 15px; outline: none;"><%= note.content %></textarea>
            
            <button type="submit">Зберегти зміни</button>
        </form>
        
        <br>

        <form action="/notes/<%= note.id %>/delete" method="POST" onsubmit="return confirm('Ви впевнені, що хочете назавжди видалити цю нотатку?');">
            <button type="submit" style="background-color: #ff4d4d; color: white;">🗑 Видалити нотатку</button>
        </form>
        
        <br>
        <a href="/notes" style="color: #888;">← Скасувати</a>
    </div>
</body>
</html>