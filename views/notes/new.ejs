<!DOCTYPE html>
<html lang="uk">
<head>
    <title>Створити нотатку</title>
    <link rel="stylesheet" href="/auth.css">
    <style>
        .tags-container {
            background: #2d2d2d;
            border: 1px solid #333;
            border-radius: 6px;
            padding: 10px;
            margin-bottom: 15px;
        }
        .tags-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
            gap: 8px;
        }
        .tag-checkbox {
            display: flex;
            align-items: center;
            padding: 8px;
            border: 1px solid #444;
            border-radius: 4px;
            background: #1e1e1e;
            cursor: pointer;
            transition: all 0.2s;
        }
        .tag-checkbox:hover {
            background: #222;
            border-color: #4da6ff;
        }
        .tag-checkbox input[type="checkbox"] {
            margin-right: 6px;
            cursor: pointer;
            accent-color: #4da6ff;
        }
        .tag-checkbox input[type="checkbox"]:checked + label {
            color: #4da6ff;
            font-weight: bold;
        }
        .tag-checkbox label {
            cursor: pointer;
            margin: 0;
            color: #ccc;
        }
        .selected-tags {
            display: flex;
            flex-wrap: wrap;
            gap: 5px;
            margin-top: 10px;
            min-height: 20px;
        }
        .tag-badge {
            background: #4da6ff;
            color: #1e1e1e;
            padding: 3px 8px;
            border-radius: 12px;
            font-size: 0.85em;
            font-weight: bold;
        }
    </style>
</head>
<body>
    <div class="auth-card">
        <h2 style="margin-top: 0;">Нова нотатка</h2>
        
        <form action="/notes" method="POST">
            <input type="text" name="title" placeholder="Заголовок" required>
            
            <textarea name="content" placeholder="Текст нотатки..." rows="5" style="width: 100%; padding: 10px; margin-bottom: 15px; border: 1px solid #333; border-radius: 6px; background-color: #2d2d2d; color: white; box-sizing: border-box; font-family: sans-serif; resize: vertical;"></textarea>
            
            <!-- Класичний вибір через кому (альтернатива) -->
            <label style="display: block; margin-bottom: 5px; color: #888; font-size: 0.9em;">Теги через кому (напр: робота, ідея)</label>
            <input type="text" name="tags_string" placeholder="Або введіть нові теги тут" style="margin-bottom: 15px;">
            
            <!-- Мультивибір існуючих тегів -->
            <% if (typeof allTags !== 'undefined' && allTags.length > 0) { %>
                <div class="tags-container">
                    <p style="margin: 0 0 10px 0; color: #4da6ff; font-weight: bold;">📌 Виберіть теги (опціонально):</p>
                    <div class="tags-grid">
                        <% allTags.forEach(tag => { %>
                            <div class="tag-checkbox">
                                <input type="checkbox" id="tag_<%= tag.name %>" name="selected_tags" value="<%= tag.name %>" onchange="updateTagBadges()">
                                <label for="tag_<%= tag.name %>">#<%= tag.name %></label>
                            </div>
                        <% }) %>
                    </div>
                    <div class="selected-tags" id="selectedTagsPreview"></div>
                </div>
            <% } %>
            
            <button type="submit">Зберегти</button>
        </form>
        
        <a href="/notes" style="display: inline-block; margin-top: 15px;">← Скасувати</a>
    </div>

    <script>
        function updateTagBadges() {
            const preview = document.getElementById('selectedTagsPreview');
            if (!preview) return; // Якщо немає елемента, виходимо
            
            const selected = Array.from(document.querySelectorAll('input[name="selected_tags"]:checked'))
                .map(el => el.value);
            
            if (selected.length === 0) {
                preview.innerHTML = '';
                return;
            }
            
            preview.innerHTML = selected.map(tag => 
                `<span class="tag-badge">#${tag}</span>`
            ).join('');
            
            // Також оновлюємо текстовий інпут
            const textInput = document.querySelector('input[name="tags_string"]');
            if (textInput && textInput.value === '') {
                textInput.value = selected.join(', ');
            }
        }
        
        // Ініціалізуємо при завантаженні
        window.addEventListener('load', updateTagBadges);
    </script>
</body>
</html>