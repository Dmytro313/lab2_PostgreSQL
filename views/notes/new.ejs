<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <title>Нова нотатка</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <div class="card">
        <h2>Створити нотатку</h2>
        
        <form action="/notes" method="POST">
            <input type="text" name="title" placeholder="Заголовок" required>
            
            <textarea name="content" placeholder="Ваш текст тут..." rows="5" 
                style="width: 100%; background: #2d2d2d; color: white; border: 1px solid #3d3d3d; border-radius: 8px; padding: 12px; margin-bottom: 15px; outline: none;"></textarea>
            
            <button type="submit">Зберегти нотатку</button>
        </form>
        
        <br>
        <a href="/notes" style="color: #888;">← Скасувати</a>
    </div>
</body>
</html>